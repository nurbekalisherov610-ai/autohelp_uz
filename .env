APP_NAME=AutoHelp
APP_ENV=dev
LOG_LEVEL=INFO

BOT_TOKEN=replace_me
DISPATCHER_CHAT_ID=-1000000000000
DISPATCHER_IDS=
DISPATCHER_GROUP_ID=
ADMIN_CHAT_ID=-1000000000000
ADMIN_IDS=
MASTER_IDS=
MASTER_LABELS=
MASTER_SECRET=master123
DISPATCHER_CONFIRM_VIDEO_KIND=video_note
DISPATCHER_CONFIRM_VIDEO_UZ=
DISPATCHER_CONFIRM_VIDEO_RU=
DISPATCHER_CONFIRM_VIDEO_EN=

# If DATABASE_URL is set, it overrides POSTGRES_* values.
# Local quick-start example:
# DATABASE_URL=sqlite+aiosqlite:///./autohelp_local.db
USE_REDIS=falsesqlite+aiosqlite:///./autohelp_local.db
DATABASE_URL=sqlite+aiosqlite:///./autohelp_local.db
USE_REDIS=false
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=autohelp
POSTGRES_USER=autohelp
POSTGRES_PASSWORD=autohelp

# If REDIS_URL is set, it overrides REDIS_* values.
REDIS_URL=
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
USE_REDIS=true

API_HOST=0.0.0.0
API_PORT=8000
TIMEZONE=Asia/Tashkent
AUTO_CREATE_SCHEMA=false
DEPENDENCY_WAIT_ATTEMPTS=30
DEPENDENCY_WAIT_DELAY_SECONDS=2
