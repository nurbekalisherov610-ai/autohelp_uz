APP_NAME=AutoHelp
APP_ENV=dev
LOG_LEVEL=INFO

BOT_TOKEN=replace_me
DISPATCHER_CHAT_ID=-1000000000000
ADMIN_CHAT_ID=-1000000000000

# If DATABASE_URL is set, it overrides POSTGRES_* values.
# Local quick-start example:
# DATABASE_URL=sqlite+aiosqlite:///./autohelp_local.db
DATABASE_URL=
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=autohelp
POSTGRES_USER=autohelp
POSTGRES_PASSWORD=autohelp

# If REDIS_URL is set, it overrides REDIS_* values.
REDIS_URL=
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
USE_REDIS=true

API_HOST=0.0.0.0
API_PORT=8000
TIMEZONE=Asia/Tashkent
AUTO_CREATE_SCHEMA=false
DEPENDENCY_WAIT_ATTEMPTS=30
DEPENDENCY_WAIT_DELAY_SECONDS=2
