# ============================================
# AutoHelp.uz Bot Configuration
# Copy this to .env and fill in your values
# ============================================

# Telegram Bot
BOT_TOKEN=your_bot_token_here
ADMIN_IDS=123456789,987654321
ADMIN_STAFF_IDS=
DISPATCHER_IDS=
MASTER_IDS=
MASTER_ROLES=
ENV_BOOTSTRAP_ENABLED=true
DISPATCHER_GROUP_ID=-1001234567890
DISPATCH_MODE=hybrid
VIDEO_CHANNEL_ID=-1001234567891
DISPATCHER_CONFIRM_VIDEO_UZ=
DISPATCHER_CONFIRM_VIDEO_RU=
DISPATCHER_CONFIRM_VIDEO_KIND=video_note
DISPATCHER_AUTO_VIDEO_DELAY_SECONDS=15

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=autohelp
DB_USER=autohelp_user
DB_PASSWORD=your_secure_password

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password
REDIS_DB=0

# Web Panel
WEB_HOST=0.0.0.0
WEB_PORT=8080
SECRET_KEY=your_secret_key_here

# Backup
BACKUP_PATH=/var/backups/autohelp
BACKUP_RETENTION_DAYS=30

# SLA Timeouts (minutes)
SLA_ASSIGN_TIMEOUT=5
SLA_ON_THE_WAY_TIMEOUT=60
SLA_CONFIRM_TIMEOUT=15
SLA_ALERT_COOLDOWN_MINUTES=30
ORDER_DRAFT_REMINDER_MINUTES=10

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/autohelp.log
